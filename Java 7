class Slip12_1 implements ActionListener
{
JFrame f;
JPanel p;
JTextField t;
JButton b;
 Thread t1;
Slip12_1()
 {
 f = new JFrame();
 p = new JPanel();
 t = new JTextField(60);
 b = new JButton("Start");
 t1 = new Thread(this);
b.addActionListener(this);
p.add(t);
p.add(b);
f.add(p);
f.setSize(400, 400);
