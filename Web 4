2) Python Program (Apriori Algorithm)
Python
from itertools import combinations
data = [
    ['Apple','Grapes','Mangoes'],
    ['Mangoes','Grapes','Apple'],
    ['Bananas','Apple']
]
items = sorted(set(i for row in data for i in row))
def support(itemset):
    count = 0
    for row in data:
        if set(itemset).issubset(set(row)):
            count += 1
    return count
min_sup = 1
L1 = []
for i in items:
    if support([i]) >= min_sup:
        L1.append([i])
L2 = []
for c in combinations(items,2):
    if support(c) >= min_sup:
        L2.append(list(c))
L3 = []
for c in combinations(items,3):
    if support(c) >= min_sup:
        L3.append(list(c))
print("Frequent Itemsets:")
print(L1)
print(L2)
print(L3)
print("\nAssociation Rules:")
for itemset in L2+L3:
    for i in range(1,len(itemset)):
        for a in combinations(itemset,i):
            b = set(itemset) - set(a)
            conf = support(itemset)/support(a)
            print(set(a),"->",b,"Confidence:",conf)
