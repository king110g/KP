#include <stdio.h>
#include <stdlib.h>

void sort(int arr[], int n) {
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

int main() {
    int req[] = {80, 150, 60, 135, 40, 35, 170};
    int n = 7;

    int head = 70;
    int disk_size = 200;  // assume
    int total_movement = 0;

    sort(req, n);

    printf("Request Order: ");

    // Move right side
    for(int i = 0; i < n; i++) {
        if(req[i] >= head) {
            printf("%d ", req[i]);
            total_movement += abs(head - req[i]);
            head = req[i];
        }
    }

    // Go to end
    total_movement += abs(head - (disk_size - 1));
    head = disk_size - 1;

    // Jump to start
    total_movement += abs(head - 0);
    head = 0;

    // Serve remaining (left side)
    for(int i = 0; i < n; i++) {
        if(req[i] < 70) {
            printf("%d ", req[i]);
            total_movement += abs(head - req[i]);
            head = req[i];
        }
    }

    printf("\nTotal Head Movement = %d\n", total_movement);

    return 0;
}
