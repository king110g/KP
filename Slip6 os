#include <stdio.h>

int main() {
    int n = 5, m = 4; // 5 processes and 4 resources
    int i, j;
    
    // Allocation Matrix
    int alloc[5][4] = {
        {0, 0, 1, 2},
        {1, 0, 0, 0},
        {1, 3, 5, 4},
        {0, 6, 3, 2},
        {0, 0, 1, 4}
    };

    // Max Matrix
    int max[5][4] = {
        {0, 0, 1, 2},
        {1, 7, 5, 0},
        {2, 3, 5, 6},
        {0, 6, 5, 2},
        {0, 6, 5, 6}
    };

    // Available Resources
    int avail[4] = {1, 5, 2, 0};

    // Need Matrix (Max - Allocation)
    int need[5][4];

    // Calculate Need Matrix
    for(i = 0; i < n; i++) {
        for(j = 0; j < m; j++) {
            need[i][j] = max[i][j] - alloc[i][j];
        }
    }

    // Print the Need Matrix
    printf("Need Matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < m; j++) {
            printf("%d ", need[i][j]);
        }
        printf("\n");
    }

    // Check if the system is in a safe state
    int finish[5] = {0}; // Finish array to keep track of process completion
    int work[4];          // Work array to store current available resources
    for(i = 0; i < m; i++) {
        work[i] = avail[i];
    }

    int safeSequence[5];
    int count = 0;

    while(count < n) {
        int found = 0;
        for(i = 0; i < n; i++) {
            if(finish[i] == 0) {
                // Check if all the need is less than or equal to available resources
                int canProceed = 1;
                for(j = 0; j < m; j++) {
                    if(need[i][j] > work[j]) {
                        canProceed = 0;
                        break;
                    }
                }

                // If process can proceed, update the work and finish arrays
                if(canProceed) {
                    for(j = 0; j < m; j++) {
                        work[j] += alloc[i][j];
                    }
                    safeSequence[count++] = i;
                    finish[i] = 1;
                    found = 1;
                }
            }
        }

        if(found == 0) {
            printf("System is NOT in a safe state.\n");
            return 0;
        }
    }

    // If we get here, the system is in a safe state
    printf("System is in a SAFE state.\nSafe sequence: ");
    for(i = 0; i < n; i++) {
        printf("P%d ", safeSequence[i]);
    }
    printf("\n");

    return 0;

