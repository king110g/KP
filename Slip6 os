int main() {
    int n, head, i, total=0;

    printf("Enter number of requests: ");
    scanf("%d",&n);

    int req[n], visited[n];
    printf("Enter disk requests: ");
    for(i=0;i<n;i++){
        scanf("%d",&req[i]);
        visited[i]=0; // mark all requests as unvisited
    }

    printf("Enter starting head position: ");
    scanf("%d",&head);

    printf("Order of service: %d ", head);

    for(int count=0; count<n; count++){
        int min_dist=1000000, idx=-1;
        for(i=0;i<n;i++){
            if(!visited[i] && abs(req[i]-head)<min_dist){
                min_dist = abs(req[i]-head);
                idx = i;
            }
        }
        // Serve the closest request
        printf("%d ", req[idx]);
        total += abs(head - req[idx]);
        head = req[idx];
        visited[idx] = 1;
    }

    printf("\nTotal head movements: %d\n", total);
    return 0;
}
