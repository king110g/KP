#include <stdio.h>
#include <stdlib.h>

int main() {
    int request[] = {56, 59, 40, 19, 91, 161, 151, 39, 185};
    int n = 9;
    int head = 48;

    int total_movement = 0;

    printf("Order of execution:\n");

    for(int i = 0; i < n; i++) {
        printf("%d -> ", request[i]);

        int movement = abs(head - request[i]);
        total_movement += movement;

        head = request[i];
    }

    printf("\n\nTotal Head Movement: %d\n", total_movement);

    return 0;
}
